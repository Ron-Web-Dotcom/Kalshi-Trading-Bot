[Unit]
Description=Kalshi AI Trading Bot
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=300
StartLimitBurst=5

[Service]
Type=simple
User=root
WorkingDirectory=/root/trading-bot
Environment="PYTHONUNBUFFERED=1"
EnvironmentFile=/root/trading-bot/.env
ExecStartPre=/bin/bash -c 'pkill -f bot.py 2>/dev/null; sleep 2; true'
ExecStart=/root/trading-bot/venv/bin/python /root/trading-bot/bot.py
Restart=on-failure
RestartSec=15
TimeoutStopSec=30
KillMode=control-group
StandardOutput=journal
StandardError=journal
SyslogIdentifier=kalshi-bot

[Install]
WantedBy=multi-user.target
