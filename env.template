# ============================================================
# Kalshi AI Trading Bot — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ── Kalshi API ───────────────────────────────────────────────
# Option A: RSA key auth (recommended for production)
# Get your key ID and generate RSA key at: https://trading.kalshi.com/settings/api
KALSHI_API_KEY_ID=your-key-id-uuid-here
KALSHI_PRIVATE_KEY_PATH=kalshi_private_key.pem
# Or paste PEM inline (escape newlines with \n):
# KALSHI_PRIVATE_KEY_PEM=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----

# Option B: Simple API key (demo / testing only)
KALSHI_API_KEY=your_kalshi_api_key_here

# Use demo environment (true = safe testing, false = real money)
KALSHI_USE_DEMO=true

# ── AI / Anthropic ───────────────────────────────────────────
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
AI_MODEL=claude-sonnet-4-6
AI_ENABLED=true
MIN_AI_CONFIDENCE=70.0

# ── Trading Mode ─────────────────────────────────────────────
# SAFETY: Set to false for paper trading (simulation only)
LIVE_TRADING_ENABLED=false

# Trade sizing (dollars)
BASE_TRADE_SIZE=10.0
MAX_TRADE_SIZE=100.0
MIN_TRADE_SIZE=1.0
MAX_POSITION_PCT=3.0

# ── Risk Management ──────────────────────────────────────────
MAX_DAILY_LOSS_PCT=10.0
MAX_DRAWDOWN_PCT=15.0
MAX_SECTOR_EXPOSURE_PCT=30.0
TRADE_COOLDOWN_SECONDS=30

# ── Arbitrage ────────────────────────────────────────────────
ARBITRAGE_THRESHOLD_PCT=5.0
OVERTRADE_COOLDOWN_MINUTES=5

# ── Auto-Scaling ─────────────────────────────────────────────
ENABLE_AUTO_SCALING=true
SCALE_UP_MILESTONE=50.0
SCALE_UP_FACTOR=1.25
SCALE_DOWN_MILESTONE=25.0
SCALE_DOWN_FACTOR=0.8

# ── Discord Alerts ───────────────────────────────────────────
# Get webhook from: Discord Server Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/WEBHOOK
ALERT_ON_TRADE=true
ALERT_ON_SIGNAL=false
ALERT_ON_ERROR=true

# ── AI Cost Limiting ─────────────────────────────────────────
DAILY_AI_BUDGET=10.0
ENABLE_COST_LIMITING=true
SLEEP_ON_LIMIT=true

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
ENABLE_FILE_LOGGING=true
ENABLE_CONSOLE_LOGGING=true
LOG_DIR=logs

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=sqlite:///trading_system.db
