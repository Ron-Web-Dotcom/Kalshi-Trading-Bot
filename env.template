# ============================================================
# Kalshi AI Trading Bot — Environment Configuration
# Copy this file to .env and fill in your values.
# Restart the bot after any change.
# ============================================================

# ── Kalshi API ───────────────────────────────────────────────
# Option A: RSA key auth (production — recommended)
# Get your key pair at: https://trading.kalshi.com/settings/api
KALSHI_API_KEY_ID=your-key-id-uuid-here
KALSHI_PRIVATE_KEY_PATH=kalshi_private_key.pem
# Or paste PEM inline (alternative to file):
# KALSHI_PRIVATE_KEY_PEM=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----

# Set to false for production key, true for demo/testing key
KALSHI_USE_DEMO=false

# ── AI / Anthropic ───────────────────────────────────────────
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
AI_MODEL=claude-sonnet-4-6
AI_ENABLED=true
# Minimum AI confidence % required to place a trade (0–100)
MIN_AI_CONFIDENCE=77.0

# ── Trading Mode ─────────────────────────────────────────────
# SAFETY: Keep false until you have reviewed paper trade results
LIVE_TRADING_ENABLED=false

# ── Trade Sizing (dollars) ────────────────────────────────────
BASE_TRADE_SIZE=10.0        # Starting size per trade
MAX_TRADE_SIZE=100.0        # Hard ceiling
MIN_TRADE_SIZE=1.0          # Hard floor
MAX_POSITION_PCT=3.0        # Max % of portfolio in one position
KELLY_FRACTION=0.25         # Fraction of full Kelly to use (0.25 = quarter Kelly)
# Assumed portfolio value for risk % calculations
# Set to your actual Kalshi balance; updated automatically in live mode
PORTFOLIO_VALUE=1000.0

# ── Risk Management ──────────────────────────────────────────
MAX_DAILY_LOSS_PCT=10.0     # Pause trading if daily loss hits this %
MAX_DRAWDOWN_PCT=15.0       # Portfolio drawdown circuit breaker
MAX_SECTOR_EXPOSURE_PCT=30.0 # Max % of portfolio in one market category
TRADE_COOLDOWN_SECONDS=30   # Min seconds between trades on the same ticker
# Exit thresholds (set to 0 to disable)
STOP_LOSS_PCT=50.0          # Close position if down this % from entry
TAKE_PROFIT_PCT=40.0        # Close position if up this % from entry

# ── Arbitrage ────────────────────────────────────────────────
ARBITRAGE_THRESHOLD_PCT=5.0       # Min net edge (%) to flag an arb signal
OVERTRADE_COOLDOWN_MINUTES=5      # Min gap between arb signals on same ticker

# ── Cycle Control ─────────────────────────────────────────────
MAX_TRADES_PER_CYCLE=3      # Max trades executed per 60s cycle
MAX_MARKETS_TO_SCAN=20      # How many markets the AI evaluates each cycle
MIN_MARKET_VOLUME=50        # Ignore markets with fewer contracts than this

# ── Auto-Scaling ─────────────────────────────────────────────
ENABLE_AUTO_SCALING=true
SCALE_UP_MILESTONE=50.0     # Increase size when cumulative PnL gains this $
SCALE_UP_FACTOR=1.25        # Multiply trade size by this on scale-up
SCALE_DOWN_MILESTONE=25.0   # Decrease size when cumulative PnL loses this $
SCALE_DOWN_FACTOR=0.8       # Multiply trade size by this on scale-down

# ── Discord Alerts ───────────────────────────────────────────
# Get webhook: Discord Server → channel → Edit → Integrations → Webhooks
DISCORD_WEBHOOK_URL=
ALERT_ON_TRADE=true         # Alert on every executed trade
ALERT_ON_SIGNAL=false       # Alert on arb signals (can be noisy)
ALERT_ON_ERROR=true         # Alert on bot errors

# ── AI Cost Limiting ─────────────────────────────────────────
DAILY_AI_BUDGET=10.0        # Max Claude API spend per day (USD)
ENABLE_COST_LIMITING=true
SLEEP_ON_LIMIT=true         # Sleep until midnight when limit hit (vs just skipping)

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO              # DEBUG / INFO / WARNING / ERROR
ENABLE_FILE_LOGGING=true    # Write rotating daily logs to LOG_DIR
ENABLE_CONSOLE_LOGGING=true
LOG_DIR=logs

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=sqlite:///trading_system.db
